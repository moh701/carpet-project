<?xml version="1.0" encoding="UTF-8"?>
<web-app id="ocs-webapp" version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <display-name>OCS</display-name>
    <description>OCS - Online Carpet Store Web Application</description>
    <session-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.svg</url-pattern>
        <url-pattern>*.png</url-pattern>
        <url-pattern>*.jpg</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CustomerServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.CustomerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerServlet</servlet-name>
        <url-pattern>/customers/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProducerServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.ProducerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProducerServlet</servlet-name>
        <url-pattern>/producers/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CarpetManageServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.CarpetManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CarpetManageServlet</servlet-name>
        <url-pattern>/product/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CarpetViewServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.CarpetViewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CarpetViewServlet</servlet-name>
        <url-pattern>/product-view/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>BargainHistoryServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.BargainHistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BargainHistoryServlet</servlet-name>
        <url-pattern>/product/bargain/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>HomePageServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.HomePageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomePageServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>RateServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.RateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RateServlet</servlet-name>
        <url-pattern>/product/rate/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CartServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.CartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/cart/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>RestDispatcherServlet</servlet-name>
        <servlet-class>it.unipd.dei.webapp.servlet.RestDispatcherServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RestDispatcherServlet</servlet-name>
        <url-pattern>/rest/*</url-pattern>
    </servlet-mapping>
    <resource-ref>
        <description>Connection pool to the database</description>
        <res-ref-name>jdbc/ocs</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>it.unipd.dei.webapp.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/html/admin/*</url-pattern>
        <url-pattern>/schema/roles/*</url-pattern>
        <url-pattern>/protected/*</url-pattern>
    </filter-mapping>
    <filter>
        <filter-name>LoginFilter</filter-name>
        <filter-class>it.unipd.dei.webapp.filter.LoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoginFilter</filter-name>
        <url-pattern>/html/protected/*</url-pattern>
        <url-pattern>/jsp/login/*</url-pattern>
        <url-pattern>/user/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>CustomerFilter</filter-name>
        <filter-class>it.unipd.dei.webapp.filter.CustomerFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CustomerFilter</filter-name>
        <url-pattern>/html/customer/*</url-pattern>
        <url-pattern>/schema/roles/customer/*</url-pattern>
        <url-pattern>/jsp/customers/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>ProducerFilter</filter-name>
        <filter-class>it.unipd.dei.webapp.filter.ProducerFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>ProducerFilter</filter-name>
        <url-pattern>/html/producer/*</url-pattern>
        <url-pattern>/schema/roles/producer/*</url-pattern>
        <url-pattern>/jsp/producers/*</url-pattern>
    </filter-mapping>

</web-app>